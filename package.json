{
  "name": "dpchamps-pi-skills",
  "version": "0.1.0",
  "private": true,
  "description": "Custom skills and extensions for the pi coding agent",
  "keywords": [
    "pi-package"
  ],
  "author": "dpchamps",
  "license": "MIT",
  "workspaces": [
    "extensions/*",
    "skills/*"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "format": "prettier --write .",
    "typecheck": "npx tsc --noEmit"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.4",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2"
  }
}
